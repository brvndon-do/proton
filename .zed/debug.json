[
  {
    "label": "Run gRPC Server",
    "adapter": "netcoredbg",
    "request": "launch",
    "cwd": "${ZED_WORKTREE_ROOT}/Proton.Engine/src/Proton.AppHost",
    "program": "${ZED_WORKTREE_ROOT}/Proton.Engine/src/Proton.AppHost/bin/Debug/net10.0/Proton.AppHost.dll",
    "env": {
      "ASPNETCORE_ENVIRONMENT": "Development",
    },
    "build": {
      "command": "dotnet",
      "args": [
        "build",
        "${ZED_WORKTREE_ROOT}/Proton.Engine",
        "-p:Configuration=Debug",
        "-p:TargetFramework=net10.0",
      ],
    },
  },
]
