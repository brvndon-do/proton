{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run AppHost",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Proton.Engine/src/Proton.AppHost/bin/Debug/net10.0/Proton.AppHost",
            "args": [],
            "cwd": "${workspaceFolder}/Proton.Engine/src/Proton.AppHost",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            },
            "launchSettingsFilePath": "${workspaceFolder}/Proton.Engine/src/Proton.AppHost/Properties/launchSettings.json",
            "launchSettingsProfile": "https"
        }
    ]
}